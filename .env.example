# Safety Research System - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Anthropic Claude API (Primary)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI API (Fallback)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# LLM Configuration
MAX_TOKENS=4096
TEMPERATURE=0.0

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/safety_research_db
DB_ECHO=False  # Set to True for SQL query logging

# Database Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# =============================================================================
# External API Configuration
# =============================================================================

# NCBI E-utilities (PubMed)
NCBI_API_KEY=your-ncbi-api-key-here  # Optional but recommended (10 req/s instead of 3)
NCBI_EMAIL=your-email@example.com    # Required by NCBI guidelines

# ClinicalTrials.gov API
CLINICALTRIALS_API_URL=https://clinicaltrials.gov/api/v2

# Rate Limiting
PUBMED_RATE_LIMIT=2.5  # Requests per second (use 9.0 if you have API key)
CLINICALTRIALS_RATE_LIMIT=1.0

# API Cache TTL (seconds)
API_CACHE_TTL=3600

# =============================================================================
# Redis Configuration (for caching and rate limiting)
# =============================================================================

REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# =============================================================================
# FastAPI Application Configuration
# =============================================================================

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=False  # Set to True for development

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# =============================================================================
# Authentication & Security
# =============================================================================

# JWT Configuration
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Password Hashing
BCRYPT_ROUNDS=12

# API Key for service-to-service authentication
SERVICE_API_KEY=your-service-api-key-here

# =============================================================================
# Logging Configuration
# =============================================================================

LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text
LOG_FILE=logs/safety_research.log

# =============================================================================
# Application Settings
# =============================================================================

# Environment
ENVIRONMENT=development  # development, staging, production

# Feature Flags
ENABLE_REAL_LLM_CALLS=True
ENABLE_CACHING=True
ENABLE_RATE_LIMITING=True

# Task Execution
MAX_RETRY_ATTEMPTS=3
TASK_TIMEOUT_SECONDS=300

# =============================================================================
# CLAUDE.md Compliance Settings
# =============================================================================

# Enforce strict CLAUDE.md compliance
ENFORCE_CLAUDEMD_COMPLIANCE=True
MAX_SCORE_WITHOUT_VALIDATION=80
REQUIRE_EVIDENCE_CHAIN=True
REQUIRE_LIMITATIONS_DISCLOSURE=True

# =============================================================================
# Docker & Container Configuration
# =============================================================================

# PostgreSQL (for docker-compose)
POSTGRES_DB=safety_research
POSTGRES_USER=safetyuser
POSTGRES_PASSWORD=changeme  # CHANGE THIS IN PRODUCTION!
POSTGRES_PORT=5432

# Redis (for docker-compose)
REDIS_PASSWORD=changeme  # CHANGE THIS IN PRODUCTION!
REDIS_PORT=6379

# =============================================================================
# Monitoring & Metrics
# =============================================================================

ENABLE_METRICS=true
METRICS_PORT=9090
PROMETHEUS_PORT=9091
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin  # CHANGE THIS IN PRODUCTION!

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=*  # Use specific domains in production

# =============================================================================
# Backup & Disaster Recovery
# =============================================================================

BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Cron format: daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups

# =============================================================================
# Performance Settings
# =============================================================================

MAX_CONCURRENT_TASKS=10
CONNECTION_POOL_SIZE=20
CONNECTION_POOL_MAX_OVERFLOW=10
STATEMENT_TIMEOUT=30000  # Milliseconds
